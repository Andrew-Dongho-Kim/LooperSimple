<?xml version="1.0" encoding="utf-8"?>
<!--
  Rounded background for the native-ad "AD" attribution badge.
  The fill color is left neutral and tinted at runtime (backgroundTintList)
  so it always matches the active light/dark Compose theme.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="6dp" />
    <solid android:color="@android:color/white" />
</shape>
